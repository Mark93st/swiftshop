{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-playwright"],
      "disabled": false,
      "alwaysAllow": [],
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-postgres"],
      "disabled": false,
      "alwaysAllow": [],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    }
  }
}
